{
  "name": "ecommerce-ops-vitepress",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare:docs": "node scripts/prepare-docs.mjs",
    "check:docs": "node scripts/check-docs.mjs",
    "docs:dev": "vitepress dev docs --host 0.0.0.0",
    "docs:build": "pnpm prepare:docs && vitepress build docs",
    "docs:preview": "vitepress preview docs --host 0.0.0.0",
    "interview:dev": "vitepress dev interview --host 0.0.0.0",
    "interview:build": "vitepress build interview",
    "interview:preview": "vitepress preview interview --host 0.0.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.2",
    "playwright": "^1.61.1",
    "vitepress": "^1.6.4",
    "vue": "^3.5.22"
  },
  "dependencies": {
    "@lucide/vue": "^1.22.0"
  }
}
